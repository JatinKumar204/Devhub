{
  "ConnectionStrings": {
    "DefaultConnection": "Server=Devil-VM;Database=DevHub_DB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_256BIT_SECRET_KEY_MINIMUM_32_CHARS",
    "Issuer": "UserService",
    "Audience": "DevHub",
    "ExpiryMinutes": "60",
    "RefreshTokenDays": "7"
  },
  "FileUpload": {
    "MaxBytes": "5242880"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "UserService"
    }
  },
  "AllowedHosts": "*"
}