# DevHub Environment Variables
# Copy this to .env and fill in values — never commit .env to source control

# Database
DB_SA_PASSWORD=DevHub@2025!

# JWT — generate a strong secret: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MINIMUM_32_CHARACTERS

# Environment: Development | QA | Production
ASPNETCORE_ENVIRONMENT=Development
DEVHUB_ENV=development
